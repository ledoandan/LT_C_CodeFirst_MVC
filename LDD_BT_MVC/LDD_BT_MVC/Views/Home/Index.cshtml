@{
    ViewData["Title"] = "Home Page";
}

<style>
    /* Tùy chỉnh danh sách menu */
    .navbar-nav {
        display: flex;
        gap: 15px; /* Khoảng cách giữa các mục */
        list-style: none;
        padding: 0;
    }

    /* Tùy chỉnh các đường link */
    .nav-link {
        font-weight: 500;
        padding: 8px 16px !important;
        border-radius: 5px;
        transition: all 0.3s ease;
        text-decoration: none;
        color: #333 !important;
    }

        /* Hiệu ứng khi di chuột qua (Hover) */
        .nav-link:hover {
            background-color: #007bff; /* Màu xanh đặc trưng */
            color: white !important;
            box-shadow: 0 4px 8px rgba(0, 123, 255, 0.2);
        }

    /* Hiệu ứng khi mục đang được chọn (Active) */
    .nav-item.active .nav-link {
        border-bottom: 2px solid #007bff;
    }
</style>

<ul class="navbar-nav flex-grow-1">
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="KhoaHocModels" asp-action="Index">Khóa học</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="SinhVienModels" asp-action="Index">Sinh viên</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="GiaoVienModels" asp-action="Index">Giáo viên</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="LopModels" asp-action="Index">Lớp học</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="DangKyLopModels" asp-action="Index">Đăng ký</a>
    </li>
</ul>
