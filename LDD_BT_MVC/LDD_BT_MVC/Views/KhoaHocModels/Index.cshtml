@model IEnumerable<LDD_BT_MVC.Models.KhoaHocModel>

@{
    ViewData["Title"] = "Index";
}

<style>
    /* Tổng thể tiêu đề và nút Create */
    h1 {
        color: #2c3e50;
        font-weight: bold;
        margin-bottom: 20px;
        border-bottom: 2px solid #3498db;
        padding-bottom: 10px;
    }

    .btn-create {
        display: inline-block;
        background-color: #27ae60;
        color: white !important;
        padding: 8px 16px;
        border-radius: 5px;
        text-decoration: none;
        transition: background 0.3s;
        margin-bottom: 15px;
    }

    .btn-create:hover {
        background-color: #219150;
    }

    /* Tùy chỉnh bảng */
    .custom-table {
        width: 100%;
        border-collapse: collapse;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border-radius: 8px;
        overflow: hidden; /* Để bo góc hoạt động */
    }

    .custom-table thead {
        background-color: #007bff;
        color: white;
    }

    .custom-table th, .custom-table td {
        padding: 12px 15px;
        text-align: left;
        border-bottom: 1px solid #ddd;
    }

    /* Hiệu ứng dòng xen kẽ và hover */
    .custom-table tbody tr:nth-child(even) {
        background-color: #f8f9fa;
    }

    .custom-table tbody tr:hover {
        background-color: #ebf5fb;
        transition: 0.2s;
    }

    /* Style cho các nút hành động */
    .action-links a {
        text-decoration: none;
        font-weight: 500;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.9em;
    }

    .link-edit { color: #f39c12; border: 1px solid #f39c12; }
    .link-edit:hover { background: #f39c12; color: white !important; }

    .link-details { color: #3498db; border: 1px solid #3498db; margin: 0 5px; }
    .link-details:hover { background: #3498db; color: white !important; }

    .link-delete { color: #e74c3c; border: 1px solid #e74c3c; }
    .link-delete:hover { background: #e74c3c; color: white !important; }
</style>

<h1>Danh Sách Khóa Học</h1>

<p>
    <a asp-action="Create" class="btn-create"> + Thêm Khóa Học Mới</a>
</p>

<table class="custom-table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th style="text-align: center;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td style="font-weight: 600; color: #2c3e50;">
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td class="action-links" style="text-align: center;">
                <a asp-action="Edit" asp-route-id="@item.Id" class="link-edit">Sửa</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="link-details">Chi tiết</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="link-delete">Xóa</a>
            </td>
        </tr>
}
    </tbody>
</table>